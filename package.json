{
  "name": "@pantha704/job-finder",
  "version": "1.0.5",
  "description": "Fresher-focused remote job aggregator CLI — scrapes 14 job boards for Rust, TypeScript, Solana & Web3 remote roles",
  "module": "index.ts",
  "type": "module",
  "private": false,
  "bin": {
    "job-finder": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "job-finder",
    "remote-jobs",
    "fresher",
    "internship",
    "web3",
    "solana",
    "rust",
    "typescript",
    "job-scraper",
    "india",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pantha704/job-finder.git"
  },
  "homepage": "https://github.com/pantha704/job-finder#readme",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun --external playwright --external playwright-core --external electron --external chromium-bidi --external figlet",
    "prepublishOnly": "bun run build",
    "start": "bun run src/cli.ts",
    "dev": "bun run src/cli.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/figlet": "^1.7.0",
    "@types/pino": "^7.0.5",
    "bun-types": "^1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "cheerio": "1.x",
    "figlet": "^1.11.0",
    "ora": "^9.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1"
  }
}
